# Instana Configuration
INSTANA_BASE_URL=https://your-tenant.instana.io
INSTANA_API_TOKEN=your_instana_api_token_here

# OpenShift Configuration
OCP_API_URL=https://api.your-cluster.com:6443
OCP_TOKEN=your_ocp_token_here
OCP_NAMESPACE=demo-namespace

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=your_username
GITHUB_REPO_NAME=autonomous-remediation-demo

# Bob AI Agent Configuration
BOB_WEBHOOK_PORT=3000
BOB_WEBHOOK_SECRET=change_this_secret

# Application Configuration
APP_NAME=quarkus-memory-leak-app
APP_PORT=8080

# Container Registry
REGISTRY_URL=quay.io
REGISTRY_USERNAME=your_username
REGISTRY_PASSWORD=your_password

# ArgoCD Configuration
ARGOCD_SERVER=argocd-server.argocd.svc.cluster.local
ARGOCD_USERNAME=admin
ARGOCD_PASSWORD=your_argocd_password